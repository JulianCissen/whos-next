# Copy this file to .env and adjust values as needed.
# The defaults below work for local development with docker compose.

# Database
DB_DRIVER=postgres
DB_SQLITE_PATH=./data/whosnext.sqlite

# PostgreSQL (used when DB_DRIVER=postgres)
DB_HOST=postgres
DB_PORT=5432
DB_NAME=whosnext
DB_USER=postgres
DB_PASSWORD=postgres

# Service ports
BACKEND_PORT=3000
FRONTEND_PORT=4200
