{
  "name": "@whos-next/backend",
  "version": "0.0.1",
  "private": true,
  "description": "Who's Next — NestJS backend API",
  "type": "commonjs",
  "scripts": {
    "build": "nest build",
    "migrate": "mikro-orm migration:up",
    "start": "node dist/apps/backend/src/main",
    "start:dev": "nest start --watch --preserveWatchOutput --no-shell",
    "start:docker": "pnpm run migrate && pnpm run start:dev",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@mikro-orm/core": "^7.0.11",
    "@mikro-orm/migrations": "^7.0.11",
    "@mikro-orm/nestjs": "^7.0.1",
    "@mikro-orm/postgresql": "^7.0.11",
    "@mikro-orm/sqlite": "^7.0.11",
    "@nestjs/common": "^11.1.19",
    "@nestjs/core": "^11.1.19",
    "@nestjs/platform-express": "^11.1.19",
    "@whos-next/shared": "workspace:*",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2"
  },
  "devDependencies": {
    "@mikro-orm/cli": "^7.0.11",
    "@nestjs/cli": "^11.0.21",
    "@nestjs/schematics": "^11.1.0",
    "@nestjs/testing": "^11.1.19",
    "@testcontainers/postgresql": "^11.14.0",
    "@types/express": "^5.0.6",
    "@types/node": "catalog:",
    "tsx": "^4.21.0",
    "typescript": "catalog:",
    "vitest": "catalog:"
  },
  "mikro-orm": {
    "config": [
      "./mikro-orm.config.ts"
    ]
  }
}
