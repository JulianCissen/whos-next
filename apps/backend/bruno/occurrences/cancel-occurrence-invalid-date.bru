meta {
  name: Cancel Occurrence (invalid date)
  type: http
  seq: 4
}

post {
  url: {{baseUrl}}/rotations/{{slug}}/occurrences/not-a-date/cancel
  body: none
  auth: none
}

tests {
  test("status is 400", function() {
    expect(res.status).to.equal(400);
  });
  test("error code is INVALID_DATE", function() {
    expect(res.body.error).to.equal("INVALID_DATE");
  });
}
