meta {
  name: Add Member (Back)
  type: http
  seq: 1
}

post {
  url: {{baseUrl}}/rotations/{{slug}}/members
  body: json
  auth: none
}

body:json {
  {
    "name": "Alice",
    "placement": "back"
  }
}

script:post-response {
  if (res.status === 201) {
    bru.setVar("memberId", res.body.id);
  }
}
